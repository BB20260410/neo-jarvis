# ══════════════════════════════════════════════════════════════════
# Neo (Noe) — 环境配置示例 / Environment configuration example
#
# 用法 / Usage:   cp .env.example .env   然后按需取消注释 / then uncomment what you need.
# 所有条目默认注释 = 走代码内默认值（本地优先、安全保守）。
# Everything is commented out by default = in-code defaults apply (local-first, conservative).
# 不需要 .env 也能启动 / The panel starts fine without any .env at all.
# ══════════════════════════════════════════════════════════════════

# ───────────── 服务器基础 / Server basics ─────────────

# 面板端口 / Panel port（默认 / default: 51835）
#PORT=51835

# 监听地址 / Bind address（默认 127.0.0.1 仅本机；0.0.0.0 会暴露给局域网，PTY 终端等能力将随之暴露
# / default 127.0.0.1 local-only; 0.0.0.0 exposes the panel incl. the PTY terminal to your LAN）
#PANEL_HOST=127.0.0.1

# 启动时不自动打开浏览器（仅 macOS 交互终端会自动开）/ Don't auto-open the browser on start (macOS TTY only)
#PANEL_NO_OPEN=1

# 是否在启动日志打印带 owner-token 的入口 URL / Print the tokenized entry URL in the startup log
# 默认：交互终端打印明文，守护进程/重定向输出时显示 [redacted]
# Default: printed in an interactive TTY, [redacted] when running as a daemon
#NOE_PRINT_OWNER_TOKEN=1

# 系统默认 node 不是 22.x 时，指定一个 Node 22 可执行文件 / Point at a Node 22 binary if your default node isn't 22.x
#NOE_NODE_BIN=/path/to/node22/bin/node

# ───────────── 自主档位 / Autonomy profile ─────────────

# 自主功能档位 / Autonomy profile（默认 / default: free）
# free = 默认通电一批"内心生活"功能（心跳/内心独白/目标/情感/期望账本等，全本地）
# off  = 全部关闭，只留一个安静的面板
# free = a set of local "inner life" features (heartbeat, inner monologue, goals, affect,
#        expectations) are on by default; off = quiet panel, none of them run
#NOE_AUTONOMY_PROFILE=free

# 持久心跳（后台作业调度脊椎；自我进化等链路也挂在它上面）/ Persistent heartbeat (background job spine)
#NOE_HEARTBEAT=1

# 内心独白 / Inner monologue（0 关 / 0 = off）
#NOE_INNER_MONOLOGUE=1

# 对话委托桥（语音/聊天里让 Noe 代呼其他本机 AI CLI）/ Delegation bridge（默认开 / on by default; 0 = off）
#NOE_DELEGATION=1

# ───────────── 聊天与云模型 / Chat & cloud models ─────────────

# 前台聊天云模型 fallback 链（逗号分隔）/ Cloud adapter fallback chain for foreground chat (comma-separated)
# 默认 / default: minimax,codex,claude,gemini,gemini-openai,gemini-cli,litellm
#NOE_CHAT_CLOUD_CHAIN=minimax,codex,claude,gemini,gemini-openai,gemini-cli,litellm

# 前台聊天只用云模型（本地模型留给后台链路）/ Foreground chat uses cloud models only
#NOE_CHAT_CLOUD_ONLY=1

# LiteLLM / 任意 OpenAI 兼容网关 / LiteLLM or any OpenAI-compatible gateway
#NOE_LITELLM_URL=
#NOE_LITELLM_KEY=
#NOE_LITELLM_MODEL=

# ───────────── 本地模型 / Local models (LM Studio & Ollama) ─────────────

# LM Studio OpenAI 兼容端点 / LM Studio OpenAI-compatible endpoint（默认 / default: http://127.0.0.1:1234/v1）
#NOE_LMSTUDIO_URL=http://127.0.0.1:1234/v1

# LM Studio 聊天模型 id（默认跟随内置主脑配置）/ LM Studio chat model id (defaults to the built-in main-brain policy)
#NOE_LMSTUDIO_MODEL=

# 本地主脑模型 id 覆盖 / Override the local main-brain model id
#NOE_MAIN_BRAIN_MODEL=

# Ollama 端点与模型 / Ollama endpoint & model（默认 / default: http://127.0.0.1:11434）
#NOE_OLLAMA_URL=http://127.0.0.1:11434
#NOE_OLLAMA_MODEL=

# ───────────── 自我进化 / Self-evolution ─────────────

# 自我进化总开关（默认关；开启后 Noe 会在心跳里自主提出并推进对自身代码的改进 cycle）
# Master switch (default OFF; when on, Noe proposes and advances self-improvement cycles on the heartbeat)
#NOE_SELF_EVOLUTION=1

# 允许执行器真正落盘改代码（默认关 = dry-run；开启仍要过双绿测试门+多模型复核+保护路径守卫）
# Let executors actually write code changes (default OFF = dry-run; still gated by tests + review + path guards)
#NOE_SELF_EVOLUTION_REAL_APPLY=1

# 进化执行器（让 cycle 能真正调用本机 AI CLI 干活）/ Wire up evolution executors (real work via local AI CLIs)
#NOE_SELF_EVOLUTION_EXECUTORS=1

# ───────────── 语音 / Voice ─────────────

# Whisper STT 伴生服务地址 / Companion Whisper STT server（默认 / default: http://127.0.0.1:8123）
#NOE_WHISPER_URL=http://127.0.0.1:8123

# CosyVoice 本地 TTS（默认尝试使用；0 = 显式关闭）/ CosyVoice local TTS (tried by default; 0 = force off)
#NOE_COSYVOICE=0

# Kokoro TTS（1 = 启用，需本机 Kokoro 服务）/ Kokoro TTS (1 = enable, needs a local Kokoro server)
#NOE_KOKORO=1
#NOE_KOKORO_URL=

# ───────────── 视觉 / Vision ─────────────

# 视觉模型（VLM）OpenAI 兼容端点与模型 / VLM endpoint & model (OpenAI-compatible, e.g. served by LM Studio)
# 默认端点 / default endpoint: http://127.0.0.1:1234/v1
#NOE_VLM_URL=http://127.0.0.1:1234/v1
#NOE_VLM_MODEL=

# ───────────── 记忆与知识图谱 / Memory & knowledge graph ─────────────

# 记忆语义召回的嵌入 provider / Embedding provider for semantic memory recall
# ollama = 语义召回（需本机 Ollama + 嵌入模型）；hash = 零依赖降级
# ollama = semantic recall (needs local Ollama + an embedding model); hash = zero-dependency fallback
#NOE_MEMORY_EMBED_PROVIDER=ollama

# 嵌入模型 / Embedding model（默认 / default: qwen3-embedding:0.6b）
#NOE_MEMORY_EMBED_MODEL=qwen3-embedding:0.6b

# 知识图谱抽取（把对话/记忆里的实体关系写进图谱；默认关）
# Knowledge-graph ingestion (extract entities/relations from conversations; default OFF)
#NOE_KG_INGEST=1

# ───────────── 搜索 / Web search ─────────────

# 本地 SearXNG 实例（搜索兜底）/ Local SearXNG instance (search fallback)
#NOE_SEARXNG_URL=

# Brave Search API key（可选云搜索）/ Brave Search API key (optional cloud search)
#NOE_BRAVE_KEY=

# ───────────── 授权 / License ─────────────

# license 文件路径覆盖（默认 ~/.noe-panel/license.txt；没有该文件 = free 档，聊天/记忆等核心能力不受限）
# Override license file path (default ~/.noe-panel/license.txt; absent = free tier, core features unrestricted)
#NOE_LICENSE_PATH=
